<!DOCTYPE html>
<html lang="{{ app.request.locale|default('ru') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}n00rd1fy{% endblock %}</title>
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/main.css" rel="stylesheet">
    <script src="/bootstrap/js/bootstrap.bundle.min.js" defer></script>
    <script src="/jquery/jquery-3.7.0.min.js" defer></script>
    <script src="/js/app.js" defer></script>
</head>
<body class="app-body"
      data-user-created-message="{{ 'alert.user_created'|trans }}">
<div class="app-shell">
    <header class="site-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container-xl">
                <a href="/" class="navbar-brand">
                    <span class="brand-mark">n</span>
                    <span>n00rd1fy</span>
                </a>

                <ul class="navbar-nav flex-row flex-wrap gap-2 mx-lg-auto">
                    {% block header %}{% endblock %}
                </ul>

                <div class="auth-actions">
                    <div class="locale-switch" aria-label="{{ 'nav.language'|trans }}">
                        <a href="{{ path('app_locale', {'locale': 'ru'}) }}"
                           class="{{ app.request.locale == 'ru' ? 'active' : '' }}">RU</a>
                        <a href="{{ path('app_locale', {'locale': 'en'}) }}"
                           class="{{ app.request.locale == 'en' ? 'active' : '' }}">EN</a>
                    </div>
                    {% if user %}
                        <span class="user-pill">{{ user.username }}</span>
                        <button type="button" class="btn btn-outline-primary btn-sm" id="logoutUserButton">
                            {{ 'auth.logout'|trans }}
                        </button>
                    {% else %}
                        <button type="button" class="btn btn-outline-primary btn-sm" id="loginUserButton"
                                data-bs-toggle="modal" data-bs-target="#loginUserModal">{{ 'auth.login'|trans }}
                        </button>
                        <button type="button" class="btn btn-primary btn-sm" id="createUserButton"
                                data-bs-toggle="modal" data-bs-target="#createUserModal">{{ 'auth.register'|trans }}
                        </button>
                    {% endif %}
                </div>
            </div>
        </nav>
    </header>

    <main class="app-main">
        {% block body %}{% endblock %}
    </main>

    <footer class="site-footer">
        <p class="mb-2">© 2026 n00rd1fy</p>
        <ul class="nav justify-content-center">
            <li class="nav-item"><a href="https://t.me/n00rd1" class="nav-link px-2">Telegram</a></li>
            <li class="nav-item"><a href="mailto:mukhamedshin13@gmail.com" class="nav-link px-2">Gmail</a></li>
            <li class="nav-item"><a href="https://github.com/n00rd1/simple_blog_at_symfony_with_boostrap"
                                    class="nav-link px-2">GitHub</a></li>
            <li class="nav-item"><a href="https://www.linkedin.com/in/n00rd1/" class="nav-link px-2">LinkedIn</a></li>
        </ul>
    </footer>
</div>

<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel"
     aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createUserModalLabel">{{ 'auth.create_account'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3 form-group">
                    <label for="createUserUsernameInput" class="form-label">{{ 'field.username'|trans }}</label>
                    <input type="text" class="form-control" id="createUserUsernameInput"
                           placeholder="Ivan555">
                </div>
                <div class="mb-3 form-group">
                    <label for="createUserPasswordInput" class="form-label">{{ 'field.password'|trans }}</label>
                    <input type="password" class="form-control" id="createUserPasswordInput"
                           placeholder="******">
                </div>
                <div class="mb-3 form-group">
                    <label for="createUserNameInput" class="form-label">{{ 'field.first_name'|trans }}</label>
                    <input type="text" class="form-control" id="createUserNameInput" placeholder="Иван">
                </div>
                <div class="mb-3 form-group">
                    <label for="createUserSurnameInput" class="form-label">{{ 'field.last_name'|trans }}</label>
                    <input type="text" class="form-control" id="createUserSurnameInput"
                           placeholder="Петров">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'button.close'|trans }}</button>
                <button type="button" class="btn btn-primary" id="createUserSendButton">{{ 'auth.register'|trans }}</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="loginUserModal" tabindex="-1" aria-labelledby="loginUserModalLabel"
     aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="loginUserModalLabel">{{ 'auth.login_title'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="loginUserUsernameInput" class="form-label">{{ 'field.username'|trans }}</label>
                    <input type="text" class="form-control" id="loginUserUsernameInput">
                </div>
                <div class="mb-3">
                    <label for="loginUserPasswordInput" class="form-label">{{ 'field.password'|trans }}</label>
                    <input type="password" class="form-control" id="loginUserPasswordInput">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'button.close'|trans }}</button>
                <button type="button" class="btn btn-primary" id="loginUserSendButton">{{ 'auth.login'|trans }}</button>
            </div>
        </div>
    </div>
</div>
</body>
</html>
