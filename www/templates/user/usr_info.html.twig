{% extends 'base.html.twig' %}

{% block title %}{{ 'title.account'|trans }}{% endblock %}

{% block header %}
    <li class="nav-item"><a href="/" class="nav-link">{{ 'nav.feed'|trans }}</a></li>
    <li class="nav-item"><a href="/users" class="nav-link">{{ 'nav.users'|trans }}</a></li>
    <li class="nav-item"><a href="/user_info" class="nav-link active">{{ 'nav.account'|trans }}</a></li>
{% endblock %}

{% block body %}
    {% if not user %}
        <div class="not-authorized profile-panel">
            {{ 'account.not_authorized'|trans }}
        </div>
    {% else %}
        <section class="user-profile profile-panel">
            <div class="profile-heading">
                <div class="avatar">{{ user.username|slice(0, 1)|upper }}</div>
                <div>
                    <p class="section-kicker">{{ 'account.kicker'|trans }}</p>
                    <h1>{{ user.username }}</h1>
                </div>
            </div>
            <div class="profile-info">
                <div class="form-group">
                    <label for="username">{{ 'field.username'|trans }}</label>
                    <input type="text" id="username" class="form-control" value="{{ user.username }}" readonly>
                </div>
                <div class="form-group">
                    <label for="name">{{ 'field.first_name'|trans }}</label>
                    <input type="text" id="name" class="form-control" value="{{ user.name }}" readonly>
                </div>
                <div class="form-group">
                    <label for="surname">{{ 'field.last_name'|trans }}</label>
                    <input type="text" id="surname" class="form-control" value="{{ user.surname }}" readonly>
                </div>
            </div>
        </section>
    {% endif %}

{% endblock %}
