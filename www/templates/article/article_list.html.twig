{% extends 'base.html.twig' %}

{% block title %}{{ 'title.feed'|trans }}{% endblock %}

{% block header %}
    <li class="nav-item"><a href="/" class="nav-link active">{{ 'nav.feed'|trans }}</a></li>
    <li class="nav-item"><a href="/users" class="nav-link">{{ 'nav.users'|trans }}</a></li>
    <li class="nav-item"><a href="/user_info" class="nav-link">{{ 'nav.account'|trans }}</a></li>
{% endblock %}

{% block body %}
    <div class="feed-layout">
        <section class="feed-panel">
            <div class="feed-title-row">
                <div>
                    <p class="section-kicker">{{ 'feed.kicker'|trans }}</p>
                    <h1>{{ 'feed.heading'|trans }}</h1>
                </div>
                {% if user %}
                    <button type="button" class="btn btn-primary" id="addArticleButton"
                            data-bs-toggle="modal" data-bs-target="#addArticleModal">{{ 'feed.new_post'|trans }}
                    </button>
                {% endif %}
            </div>

            {% if not user %}
                <div class="auth-notice">
                    {{ 'feed.auth_notice'|trans }}
                </div>
            {% endif %}

            <div class="article-list">
                {% for article in articles %}
                    <article class="feed-item">
                        <div class="avatar">{{ article.author.username|slice(0, 1)|upper }}</div>
                        <div class="feed-content">
                            <div class="feed-meta">
                                <strong>{{ article.author.username }}</strong>
                                <span>{{ article.createdAt.format("d.m.Y H:i") }}</span>
                            </div>
                            <p class="feed-text">{{ article.text }}</p>
                            {% set articleLiked = article.id in likedArticleIds %}
                            <div class="feed-actions">
                                <button type="button"
                                        class="btn btn-sm like-button {{ articleLiked ? 'liked' : '' }}"
                                        data-article-id="{{ article.id }}"
                                        aria-pressed="{{ articleLiked ? 'true' : 'false' }}"
                                        {{ not user ? 'disabled' : '' }}>
                                    <span class="like-icon" aria-hidden="true">♥</span>
                                    <span class="like-count">{{ likeCounts[article.id]|default(0) }}</span>
                                    <span>{{ 'likes.button'|trans }}</span>
                                </button>
                                <a class="btn btn-sm btn-outline-secondary"
                                   href="{{ path('app_comments', {'articleId': article.id}) }}"
                                   role="button">{{ 'comments.link'|trans }}</a>
                            </div>
                        </div>
                    </article>
                {% else %}
                    <div class="empty-state">
                        {{ 'feed.empty'|trans }}
                    </div>
                {% endfor %}
            </div>
        </section>
    </div>

    <div class="modal fade" id="addArticleModal" tabindex="-1" aria-labelledby="addArticleModalLabel"
         aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addArticleModalLabel">{{ 'feed.create_title'|trans }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="articleTextInput" class="form-label">{{ 'feed.post_text'|trans }}</label>
                        <textarea class="form-control" id="articleTextInput" maxlength="512"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'button.close'|trans }}</button>
                    <button type="button" class="btn btn-primary" id="addArticleSendButton">{{ 'button.publish'|trans }}</button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
